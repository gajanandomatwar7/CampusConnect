<!-- a single login page for both teachers and student,at post route in api.routes.js get the role from "req.query.role"and depending on the role check in teachermodel or studentmodel
home.ejs is made to pass the role in the url,  -->
<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= role %> Login</title>

<style>
    body {
        font-family: Arial, sans-serif;
        background: #f4f6f8;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
    }

    .container {
        background: white;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        width: 300px;
    }

    h2 {
        text-align: center;
        margin-bottom: 20px;
    }

    input {
        width: 100%;
        padding: 10px;
        margin: 10px 0;
    }

    button {
        width: 100%;
        padding: 10px;
        background: #007bff;
        color: white;
        border: none;
        cursor: pointer;
    }

    button:hover {
        background: #0056b3;
    }

    .switch {
        margin-top: 10px;
        text-align: center;
    }

    a {
        text-decoration: none;
        color: #007bff;
    }
</style>

</head>
<body>

<div class="container">
    <h2><%= role === 'teacher' ? 'Faculty Login' : 'Student Login' %></h2>

    <form action="/api/login?role=<%= role %>" method="POST">
        
        <% if(role === 'teacher'){ %>
            <input type="text" name="userName" placeholder="Username" required>
        <% } else { %>
            <input type="text" name="userName" placeholder="Username" required>
        <% } %>

        <input type="password" name="password" placeholder="Password" required>

        <button type="submit">Login</button>
    </form>

    <div class="switch">
        <% if(role === 'teacher'){ %>
            <a href="/login?role=student">Login as Student</a>
        <% } else { %>
            <a href="/login?role=faculty">Login as Faculty</a>
        <% } %>
    </div>
</div>


</body>
</html>
