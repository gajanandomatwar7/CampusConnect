<!DOCTYPE html>
<html>

<head>
    <title>Find Teacher</title>

    <style>
        body {
            font-family: Arial;
        }

        .search-box {
            text-align: center;
            margin: 20px;
        }

        input {
            padding: 8px;
            width: 250px;
        }

        button {
            padding: 8px 12px;
            cursor: pointer;
        }

        .container {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            justify-content: center;
        }

        .card {
            border: 1px solid #ddd;
            padding: 15px;
            width: 200px;
            border-radius: 8px;
            background: #f9f9f9;
            text-align: center;
        }

        .card h3 {
            margin: 5px 0;
        }

        .chat-btn {
            margin-top: 10px;
            background: #007bff;
            color: white;
            border: none;
            padding: 6px 10px;
            border-radius: 5px;
        }
    </style>
</head>

<body>


    <h2 style="text-align:center;">Find Teacher</h2>

    <!-- SEARCH -->
    <div class="search-box">
        <input type="text" id="searchInput" placeholder="Search by name..." />
        <button onclick="fetchTeachers()">Search</button>
    </div>

    <!-- RESULTS -->
    <div class="container" id="teacherContainer"></div>

    <script>
        const studentId = "<%= studentId %>";
        let role;
        if (studentId) {
            role = "student";
        }

        async function fetchTeachers() {
            console.log("function called");

            const search = document.getElementById("searchInput").value;

            const res = await fetch(`/api/find-teacher?search=${search}`);
            const data = await res.json();

            console.log("API response:", data);
            const container = document.getElementById("teacherContainer");
            container.innerHTML = "";

            if (!Array.isArray(data)) {
                console.error("Expected array but got:", data);
                container.innerHTML = "<p>Error loading teachers</p>";
                return;
            }

            data.forEach(t => {
                const div = document.createElement("div");
                div.className = "card";

                div.innerHTML = `<h3>${t.firstName} ${t.lastName}</h3>`;

                div.style.cursor = "pointer";

                div.onclick = () => {
                    window.location.href = `/profile?id=${t.username}&role=${role}`;
                };

                container.appendChild(div);
            });
        }


        // load all teachers initially
        fetchTeachers();
    </script>

</body>

</html>